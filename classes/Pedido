<?php
declare(strict_types=1);

class Pedido {

    private array $produtos = [];

    public function __construct(
        private Cliente $cliente,
        private string $status
    ) {}

    public function adicionarProduto(Produto $produto): bool {

        if ($produto->verificarEstoque()) {

            $this->produtos[] = $produto;
            $produto->diminuirEstoque();

            return true;
        }

        return false;
    }

    public function calcularTotal(): float {

        $total = 0;

        foreach ($this->produtos as $produto) {
            $total += $produto->getPreco();
        }

        return $total;
    }

    public function quantidadeProdutos(): int {
        return count($this->produtos);
    }

    public function verificarFreteGratis(): string {

        if ($this->calcularTotal() >= 50) {

            return "
            <span class='badge bg-success fs-6'>
                Frete Grátis
            </span>
            ";
        }

        return "
        <span class='badge bg-warning text-dark fs-6'>
            Frete Pago
        </span>
        ";
    }

    public function exibirPedido(): string {

        $html = "
        <div class='card p-4 mb-3'>

            <h4 class='fw-bold mb-4'>
                Pedido
            </h4>

            <p>
                <strong>Cliente:</strong>
                ".$this->cliente->getNome()."
            </p>

            <p>
                <strong>Quantidade de Produtos:</strong>
                ".$this->quantidadeProdutos()."
            </p>

            <h5 class='mt-4'>
                Produtos
            </h5>

            <ul class='list-group mb-4'>
        ";

        foreach ($this->produtos as $produto) {

            $html .= "
            <li class='list-group-item'>
                ".$produto->getNome()."
            </li>
            ";
        }

        $html .= "
            </ul>

            <p class='fs-3 fw-bold text-success'>
                Total: R$ ".$this->calcularTotal()."
            </p>

            <p>
                ".$this->verificarFreteGratis()."
            </p>

            <p>
                <strong>Status:</strong> {$this->status}
            </p>

        </div>
        ";

        return $html;
    }
}